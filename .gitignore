data/rag*/
data/packs/
data/downloads/
data/**/*.jsonl
data/**/*.f32
data/**/*.bin
data/**/*.onnx
data/**/*.ort
data/**/*.npy
data/**/*.npz
data/**/*.parquet
data/**/*.sqlite
data/**/*.db
!data/README.md

